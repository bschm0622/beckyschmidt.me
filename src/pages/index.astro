---
import Layout from "@/layouts/Layout.astro";
import BlogReel from "@/components/BlogReel.astro";
import { getCollection } from "astro:content";
import { Content as Hero } from "@/story/hero.md";
import { Content as BuildingIntro } from "@/story/building.md";
import { Content as Beliefs } from "@/story/beliefs.md";
import { Content as Contact } from "@/story/contact.md";

// All homepage copy lives in src/story/*.md — edit those files, not this one.
const caseStudies = (await getCollection("building")).sort(
  (a, b) => a.data.order - b.data.order
);
---

<Layout
  title="Home"
  description="Becky Schmidt is a senior product manager who builds: AI products at Octane11 by day, her own production systems at night."
>
  <div class="mx-auto w-full space-y-14">

    <!-- Story: edit src/story/hero.md -->
    <section class="typography">
      <Hero />
    </section>

    <!-- Building: intro in src/story/building.md, cards from src/building/*.md -->
    <section class="space-y-4">
      <div class="typography">
        <BuildingIntro />
      </div>
      <div class="divide-y divide-muted border-y border-muted">
        {caseStudies.map((cs) => (
          <div class="py-4">
            <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
              <a
                href={`/building/${cs.id}`}
                class="text-base font-medium text-foreground hover:underline decoration-1"
              >
                {cs.data.title}
              </a>
              <div class="flex shrink-0 items-center gap-3">
                {cs.data.links.map((link) => (
                  <a
                    href={link.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-sm text-muted-foreground hover:text-foreground transition-colors"
                  >
                    {link.label} ↗
                  </a>
                ))}
              </div>
            </div>
            <p class="text-sm text-muted-foreground mt-1 leading-snug">{cs.data.tagline}</p>
            <a
              href={`/building/${cs.id}`}
              class="text-sm text-muted-foreground hover:text-foreground transition-colors mt-1.5 inline-block"
            >
              read the story →
            </a>
          </div>
        ))}
      </div>
    </section>

    <!-- What drives me: edit src/story/beliefs.md -->
    <section class="typography">
      <Beliefs />
    </section>

    <!-- Notes -->
    <section class="space-y-3">
      <div class="flex items-baseline justify-between">
        <h2 class="text-2xl font-medium leading-[1.3] tracking-tight text-foreground mb-4">Notes</h2>
        <a href="/notes" class="text-sm text-muted-foreground hover:text-foreground transition-colors">View all →</a>
      </div>
      <BlogReel preview={true} />
    </section>

    <!-- Contact / closing CTA: edit src/story/contact.md -->
    <section class="typography">
      <Contact />
    </section>

  </div>
</Layout>
