---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Page Not Found" description="404">
    <div
        class="w-full flex justify-center mt-5 md:mt-10"
        data-pagefind-ignore="all"
    >
        <div
            class="w-full max-w-2xl flex flex-col items-center justify-center text-center gap-6"
        >
            <h1>
                You found a secret page!
                <br />
                Just kidding. It’s broken.
            </h1>
            <div class="flex gap-4">
                <a href="/">Home</a>
                <a href="/notes">Notes</a>
                <a href="/work">Work</a>
            </div>
        </div>
    </div>
</Layout>
