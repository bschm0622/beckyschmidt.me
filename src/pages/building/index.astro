---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";

const caseStudies = (await getCollection("building")).sort(
  (a, b) => a.data.order - b.data.order
);
---

<Layout
  title="Building"
  description="Products Becky Schmidt has built and runs end to end: job boards, BiblePlan, and the tools behind this site."
>
  <div class="mx-auto w-full">
    <h1 class="text-3xl font-bold leading-[1.1] tracking-[-0.03em] mb-3">Building</h1>
    <p class="text-base leading-7 text-muted-foreground mb-8">
      Things I've built and run end to end: the code, the pipelines, the deploys, and the growth. Each one has a story.
    </p>
    <div class="divide-y divide-muted border-y border-muted">
      {caseStudies.map((cs) => (
        <div class="py-4">
          <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
            <a
              href={`/building/${cs.id}`}
              class="text-base font-medium text-foreground hover:underline decoration-1"
            >
              {cs.data.title}
            </a>
            <div class="flex shrink-0 items-center gap-3">
              {cs.data.links.map((link) => (
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm text-muted-foreground hover:text-foreground transition-colors"
                >
                  {link.label} ↗
                </a>
              ))}
            </div>
          </div>
          <p class="text-sm text-muted-foreground mt-1 leading-snug">{cs.data.tagline}</p>
          <a
            href={`/building/${cs.id}`}
            class="text-sm text-muted-foreground hover:text-foreground transition-colors mt-1.5 inline-block"
          >
            read the story →
          </a>
        </div>
      ))}
    </div>
  </div>
</Layout>
