---
import DefaultLayout from "@/layouts/DefaultLayout.astro";
import NotesReel from "@/components/NotesReel.astro";
import { getCollection } from "astro:content";
import NoteTag from "@/components/ui/NoteTag.astro";
import { slugifyStr } from "@/utils/Slugify";

const allPosts = await getCollection("notes");

// Step 1: Count how many posts per tag
const tagCounts = allPosts.reduce(
    (acc, post) => {
        (post.data.tags || []).forEach((tag) => {
            acc[tag] = (acc[tag] || 0) + 1;
        });
        return acc;
    },
    {} as Record<string, number>,
);

// Step 2: Get all tags sorted by count descending
const allTags = Object.keys(tagCounts).sort(
    (a, b) => tagCounts[b] - tagCounts[a],
);
---

<DefaultLayout title="Notes" description="Becky's notes">
    <div class="mx-auto w-full space-y-10">
        <div class="space-y-6">
            <h1>Notes</h1>

            <div class="flex flex-wrap items-center gap-2">
                <span class="text-sm text-muted-foreground whitespace-nowrap">Filter by tag:</span>
                {
                    allTags.map((tag) => (
                        <NoteTag
                            href={`/notes/tag/${slugifyStr(tag)}/`}
                            key={tag}
                        >
                            {tag} ({tagCounts[tag]})
                        </NoteTag>
                    ))
                }
            </div>
        </div>

        <NotesReel posts={allPosts} />
    </div>
</DefaultLayout>
