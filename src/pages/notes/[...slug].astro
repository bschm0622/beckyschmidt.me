---
import { getCollection, render } from "astro:content";
import NoteLayout from "@/layouts/NoteLayout.astro";
import ReactionApp from "@/components/ReactionApp";

export async function getStaticPaths() {
    const posts = await getCollection("notes");
    return posts.map((post) => ({
        params: { slug: post.id },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content, remarkPluginFrontmatter } = await render(post);
const minutesRead = remarkPluginFrontmatter?.minutesRead ?? "";
const slug = post.data.slug;
---

<NoteLayout minutesRead={minutesRead} frontmatter={post.data}>
    <Content />
    <ReactionApp client:visible postId={slug} />
    <a href="/notes" class="text-sm text-muted-foreground hover:text-foreground transition-colors mt-8 inline-block">
        all notes
    </a>
</NoteLayout>
