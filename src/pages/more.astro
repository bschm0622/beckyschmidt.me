---
import Layout from "@/layouts/Layout.astro";

const pages = [
    {
        label: "Uses",
        href: "/uses",
        description: "Tools I use for product and building.",
    },
    {
        label: "Colophon",
        href: "/colophon",
        description: "How this site is built.",
    },
];
---

<Layout title="More" description="A few extra pages that don't fit anywhere else.">
    <div class="mx-auto w-full mt-5 md:mt-10 space-y-10">
        <h1>More</h1>
        <div class="divide-y divide-border">
            {pages.map((page) => (
                <div class="py-4 first:pt-0">
                    <a href={page.href} class="hover:underline font-medium">{page.label}</a>
                    {page.description && (
                        <p class="text-sm text-tertiary mt-0.5">{page.description}</p>
                    )}
                </div>
            ))}
        </div>
    </div>
</Layout>
