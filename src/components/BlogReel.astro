---
import FormattedDate from "./ui/FormattedDate.astro";
import BlogTag from "./ui/BlogTag.astro";
import { slugifyStr } from "@/utils/Slugify";

const { posts = null, preview = false } = Astro.props;

let postsToShow;

if (posts) {
  postsToShow = posts.sort(
    (a: any, b: any) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
  );
  if (preview) {
    postsToShow = postsToShow.slice(0, 5);
  }
} else {
  const allPosts = await import("astro:content").then(mod => mod.getCollection("blog"));
  const sortedPosts = allPosts.sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
  );
  postsToShow = preview ? sortedPosts.slice(0, 5) : sortedPosts;
}
---

<div class="space-y-4">
  {postsToShow.map((post: any) => (
    <div>
      <div class="flex items-baseline justify-between gap-6">
        <div class="flex items-baseline gap-2 flex-wrap min-w-0">
          <a
            href={`/notes/${post.id}/`}
            class="font-medium leading-snug shrink-0"
          >
            {post.data.title}
          </a>
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="hidden md:flex flex-wrap gap-1.5">
              {post.data.tags.map((tag: any) => (
                <BlogTag href={`/notes/tag/${slugifyStr(tag)}/`}>{tag}</BlogTag>
              ))}
            </div>
          )}
        </div>
        <FormattedDate date={post.data.pubDate} class="text-sm text-tertiary shrink-0" />
      </div>
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="flex md:hidden flex-wrap gap-1.5 mt-2">
          {post.data.tags.map((tag: any) => (
            <BlogTag href={`/notes/tag/${slugifyStr(tag)}/`}>{tag}</BlogTag>
          ))}
        </div>
      )}
    </div>
  ))}

</div>
