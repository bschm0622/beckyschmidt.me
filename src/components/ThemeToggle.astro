---
const uniqueId = `themeToggle-${crypto.randomUUID().slice(0, 8)}`;
---

<button
    id={uniqueId}
    type="button"
    aria-label="Toggle theme"
    class="theme-toggle-btn flex items-center justify-center w-9 h-9 rounded-lg transition-all cursor-pointer hover:bg-foreground/13"
>
    <!-- Moon icon - shows in light mode (click to go dark) -->
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="dark:hidden" xmlns="http://www.w3.org/2000/svg">
        <path d="M21.5 14.0784C20.3003 14.7189 18.9301 15.0821 17.4751 15.0821C12.7491 15.0821 8.91792 11.2509 8.91792 6.52485C8.91792 5.06986 9.28105 3.69968 9.92163 2.5C5.66765 3.49698 2.5 7.31513 2.5 11.8731C2.5 17.1899 6.8101 21.5 12.1269 21.5C16.6849 21.5 20.503 18.3324 21.5 14.0784Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <!-- Sun icon - shows in dark mode (click to go light) -->
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="dark:block hidden" xmlns="http://www.w3.org/2000/svg">
        <path d="M17 12C17 14.7614 14.7614 17 12 17C9.23858 17 7 14.7614 7 12C7 9.23858 9.23858 7 12 7C14.7614 7 17 9.23858 17 12Z" stroke="currentColor" stroke-width="1.5"/>
        <path d="M12 2V3.5M12 20.5V22M19.0708 19.0713L18.0101 18.0106M5.98926 5.98926L4.9286 4.9286M22 12H20.5M3.5 12H2M19.0713 4.92871L18.0106 5.98937M5.98975 18.0107L4.92909 19.0714" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
    <span class="sr-only">Toggle theme</span>
</button>

<script is:inline define:vars={{ buttonId: uniqueId }}>
    const THEME_COLORS = { dark: "#18181b", light: "#ffffff" };

    const updateThemeColor = (isDark) => {
        const meta = document.getElementById("theme-color-meta");
        if (meta) meta.setAttribute("content", isDark ? THEME_COLORS.dark : THEME_COLORS.light);
    };

    const applyThemeFromLocalStorage = () => {
        const theme = localStorage.getItem("theme");
        if (theme === "dark") {
            document.documentElement.classList.remove("light");
            document.documentElement.classList.add("dark");
            updateThemeColor(true);
        } else if (theme === "light") {
            document.documentElement.classList.remove("dark");
            document.documentElement.classList.add("light");
            updateThemeColor(false);
        }
    };

    const handleToggleClick = () => {
        document.documentElement.classList.toggle("dark");
        const isDark = document.documentElement.classList.contains("dark");
        document.documentElement.classList.toggle("light", !isDark);
        localStorage.setItem("theme", isDark ? "dark" : "light");
        updateThemeColor(isDark);
    };

    const setupThemeToggleButton = () => {
        const toggleButton = document.getElementById(buttonId);
        if (toggleButton) {
            toggleButton.removeEventListener("click", handleToggleClick); // Prevent duplicate listeners
            toggleButton.addEventListener("click", handleToggleClick);
        }
    };

    // For View Transitions: set the theme on the *incoming* document before it's
    // swapped in, so the transition snapshot never captures the wrong theme (no flash).
    document.addEventListener("astro:before-swap", (event) => {
        const theme = localStorage.getItem("theme") === "dark" ? "dark" : "light";
        const root = event.newDocument.documentElement;
        root.classList.remove("light", "dark");
        root.classList.add(theme);
    });

    // After swap, sync the theme-color meta tag (its element is replaced on swap).
    document.addEventListener("astro:after-swap", applyThemeFromLocalStorage);

    // For initial load and re-attaching button listener after page transitions:
    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", setupThemeToggleButton);
    } else {
        setupThemeToggleButton();
    }
    document.addEventListener("astro:page-load", setupThemeToggleButton);
</script>
