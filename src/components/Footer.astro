---
import { SITE } from "@/siteConfig";

const footerLinks = SITE.footerNav ?? [];
---

<footer class="px-6 py-10 text-sm text-tertiary">
    <div class="flex flex-wrap gap-x-2 gap-y-1 justify-center md:justify-end max-w-3xl mx-auto">
        {footerLinks.map((link) => (
            <>
                <a href={link.href} class="hover:underline whitespace-nowrap">
                    {link.label}
                </a>
                <span aria-hidden="true">•</span>
            </>
        ))}
        <a
            href="https://astro.build"
            class="hover:underline whitespace-nowrap"
            target="_blank"
            rel="noopener noreferrer"
        >
            Made with Astro
        </a>
        <span aria-hidden="true">•</span>
        <a href="/rss.xml" class="hover:underline whitespace-nowrap">
            RSS
        </a>
    </div>
</footer>
