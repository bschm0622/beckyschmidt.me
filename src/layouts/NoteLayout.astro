---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/Navbar.astro";
import SearchModal from "@/components/SearchModal.astro";
import FormattedDate from "@/components/ui/FormattedDate.astro";
import NoteTag from "@/components/ui/NoteTag.astro";
import { SITE } from "@/siteConfig";

const {
    image,
    canonicalURL,
    frontmatter,
    slug,
    minutesRead,
} = Astro.props;
const { tags } = frontmatter as { tags?: string[] };

const siteOrigin = Astro.site ?? SITE.href;
const articleUrl = new URL(`/notes/${slug}`, siteOrigin).toString();
const imageUrl = image ? new URL(image, siteOrigin).toString() : new URL("/og.png", siteOrigin).toString();

// Format date for schema.org
const pubDate = frontmatter.pubDate instanceof Date
    ? frontmatter.pubDate.toISOString()
    : new Date(frontmatter.pubDate).toISOString();

const blogPostingSchema = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": frontmatter.title,
    "description": frontmatter.description,
    "image": imageUrl,
    "url": articleUrl,
    "datePublished": pubDate,
    "author": {
        "@type": "Person",
        "name": "Becky Schmidt",
        "url": siteOrigin,
        "jobTitle": "Senior Product Manager"
    },
    "publisher": {
        "@type": "Person",
        "name": "Becky Schmidt",
        "url": siteOrigin
    },
    "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": articleUrl
    },
    "keywords": tags?.join(", ") || "",
    "inLanguage": SITE.locale
};
---

<BaseLayout
    title={frontmatter.title}
    description={frontmatter.description}
    image={image}
    canonicalURL={canonicalURL}
>
    <!-- BlogPosting Schema.org Structured Data -->
    <script slot="head" is:inline type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />

    <div id="scroll-progress" class="fixed top-0 left-0 z-50 h-1 bg-primary"></div>
    <Navbar />
    <main class="px-4 pb-16 mt-4 md:mt-6 flex-1 mx-auto w-full max-w-3xl typography">
        <!-- Main Content -->
        <h1 class="mt-0 mb-3">{frontmatter.title}</h1>
        <div class="flex flex-wrap items-center gap-3 text-sm text-muted-foreground mb-8">
            {frontmatter.pubDate && <FormattedDate date={frontmatter.pubDate} />}
            {minutesRead && frontmatter.pubDate && <span>·</span>}
            {minutesRead && <span>{minutesRead}</span>}
            {tags && tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5">
                    {tags.map((tag: string) => (
                        <NoteTag href={`/notes/tag/${tag}`}>{tag}</NoteTag>
                    ))}
                </div>
            )}
        </div>

        <slot />
    </main>

    <SearchModal />
</BaseLayout>

<script>
    /** scroll progress bar — throttled to one update per animation frame */
    let ticking = false;
    function updateScrollProgress() {
        const scrollableHeight =
            document.documentElement.scrollHeight - window.innerHeight;
        const progressBar = document.getElementById("scroll-progress");
        if (progressBar) {
            const progress = scrollableHeight > 0 ? (window.scrollY / scrollableHeight) * 100 : 0;
            progressBar.style.width = progress + "%";
        }
        ticking = false;
    }
    window.addEventListener("scroll", () => {
        if (!ticking) {
            ticking = true;
            requestAnimationFrame(updateScrollProgress);
        }
    });

    /** Attach copy buttons to code blocks */
    function attachCopyButtons() {
        const copyButtonLabel = "Copy";

        const codeBlocks = Array.from(document.querySelectorAll("pre"));

        for (const codeBlock of codeBlocks) {
            const wrapper = document.createElement("div");
            wrapper.style.position = "relative";

            // Wrap <pre> with wrapper
            codeBlock.parentNode?.insertBefore(wrapper, codeBlock);
            wrapper.appendChild(codeBlock);

            // Create copy button
            const copyButton = document.createElement("button");
            copyButton.className =
                "copy-code absolute end-3 -top-3 rounded bg-muted border border-muted px-2 py-1 text-xs leading-4 text-foreground font-medium";
            copyButton.textContent = copyButtonLabel;

            // Append copy button to wrapper
            wrapper.appendChild(copyButton);

            // Copy button handler
            copyButton.addEventListener("click", async () => {
                const code = codeBlock.querySelector("code");
                const text = code?.innerText ?? "";
                await navigator.clipboard.writeText(text);

                copyButton.textContent = "Copied";
                setTimeout(() => {
                    copyButton.textContent = copyButtonLabel;
                }, 700);
            });
        }
    }
    attachCopyButtons();
</script>
