---
import "@/styles/global.css";
import BaseHead from "@/components/BaseHead.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
import SearchModal from "@/components/SearchModal.astro";
import FormattedDate from "@/components/ui/FormattedDate.astro";
import BlogTag from "@/components/ui/BlogTag.astro";
import { SITE } from "@/siteConfig";

const {
    title,
    description,
    image,
    canonicalURL,
    frontmatter,
    slug,
    minutesRead,
} = Astro.props;
const { tags } = frontmatter as { tags?: string[] };

const siteOrigin = Astro.site ?? SITE.href;
const articleUrl = new URL(`/notes/${slug}`, siteOrigin).toString();
const imageUrl = image ? new URL(image, siteOrigin).toString() : new URL("/og.png", siteOrigin).toString();

// Format date for schema.org
const pubDate = frontmatter.pubDate instanceof Date
    ? frontmatter.pubDate.toISOString()
    : new Date(frontmatter.pubDate).toISOString();

const blogPostingSchema = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": frontmatter.title,
    "description": frontmatter.description,
    "image": imageUrl,
    "url": articleUrl,
    "datePublished": pubDate,
    "author": {
        "@type": "Person",
        "name": "Becky Schmidt",
        "url": siteOrigin,
        "jobTitle": "Senior Product Manager"
    },
    "publisher": {
        "@type": "Person",
        "name": "Becky Schmidt",
        "url": siteOrigin
    },
    "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": articleUrl
    },
    "keywords": tags?.join(", ") || "",
    "inLanguage": SITE.locale
};
---

<!doctype html>
<html lang="en" class="light h-full">
    <head>
        <BaseHead
            title={frontmatter.title}
            description={frontmatter.description}
            image={image}
            canonicalURL={canonicalURL}
        />
        <!-- BlogPosting Schema.org Structured Data -->
        <script is:inline type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />
    </head>
    <body
        class="bg-background text-foreground transition-colors min-h-screen flex flex-col"
    >
        <div
            id="scroll-progress"
            class="fixed top-0 left-0 z-50 h-1 bg-primary"
        >
        </div>
        <Navbar />
        <main class="px-4 flex-1 mx-auto w-full max-w-3xl typography">
            <!-- Main Content -->
            <h1 class="mb-3">{frontmatter.title}</h1>
            <div class="flex flex-wrap items-center gap-3 text-sm text-tertiary mb-8">
                {frontmatter.pubDate && <FormattedDate date={frontmatter.pubDate} />}
                {minutesRead && frontmatter.pubDate && <span>·</span>}
                {minutesRead && <span>{minutesRead}</span>}
                {tags && tags.length > 0 && (
                    <div class="flex flex-wrap gap-1.5">
                        {tags.map((tag: string) => (
                            <BlogTag href={`/notes/tag/${tag}`}>{tag}</BlogTag>
                        ))}
                    </div>
                )}
            </div>

      <slot />
    </main>

    <Footer />
    <SearchModal />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }

  /* Prevent flash of unstyled content */
  html:not(.light):not(.dark) {
    visibility: hidden;
  }

  html.light,
  html.dark {
    visibility: visible;
  }
</style>

<script>
    /** scroll progress bar */
    window.addEventListener("scroll", function () {
        const scrollableHeight =
            document.documentElement.scrollHeight - window.innerHeight;
        const scrolled = window.scrollY;
        const progressBar = document.getElementById("scroll-progress");

        if (progressBar) {
            const progress = (scrolled / scrollableHeight) * 100;
            progressBar.style.width = progress + "%";
        }
    });

    /** Attach copy buttons to code blocks */
    function attachCopyButtons() {
        const copyButtonLabel = "Copy";

        const codeBlocks = Array.from(document.querySelectorAll("pre"));

    for (const codeBlock of codeBlocks) {
      const wrapper = document.createElement("div");
      wrapper.style.position = "relative";

            // Wrap <pre> with wrapper
            codeBlock.parentNode?.insertBefore(wrapper, codeBlock);
            wrapper.appendChild(codeBlock);

            // Create copy button
            const copyButton = document.createElement("button");
            copyButton.className =
                "copy-code absolute end-3 -top-3 rounded bg-muted border border-muted px-2 py-1 text-xs leading-4 text-foreground font-medium";
            copyButton.textContent = copyButtonLabel;

            // Append copy button to wrapper
            wrapper.appendChild(copyButton);

            // Copy button handler
            copyButton.addEventListener("click", async () => {
                const code = codeBlock.querySelector("code");
                const text = code?.innerText ?? "";
                await navigator.clipboard.writeText(text);

                copyButton.textContent = "Copied";
                setTimeout(() => {
                    copyButton.textContent = copyButtonLabel;
                }, 700);
            });
        }
    }
    attachCopyButtons();
</script>
